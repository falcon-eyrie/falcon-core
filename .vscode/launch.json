{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Falcon (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/falcon",
            "args": [
                // Replace with your graph.
                // While debugging, graphs are located under build/resources/
                // In the case below, falcon will try to load build/resources/my_graph.yaml
                "my_graph.yaml"
            ],
            "cwd": "${workspaceFolder}/build/debug",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "make",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": false
                }
            ]
        }
    ]
}